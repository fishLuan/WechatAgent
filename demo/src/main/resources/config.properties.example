# ==================== LLM 大模型配置 ====================
# 支持所有兼容 OpenAI Chat Completions 协议的服务：
#  - 通义千问 Qwen:    https://dashscope.aliyuncs.com/compatible-mode/v1（推荐，支持视觉和图片生成）
#  - DeepSeek:         https://api.deepseek.com/v1
#  - 智谱:             https://open.bigmodel.cn/api/paas/v4
#  - 字节豆包:         https://ark.cn-beijing.volces.com/api/v3
#  - OpenAI:           https://api.openai.com/v1
#  - 本地 Ollama 等

# 请填入你自己的 API Key，不要提交真实 key 到仓库！
llm.base-url=你的_base_url
llm.api-key=你的_api_key
llm.model=qwen-plus

# 可选参数
llm.system-prompt=你是一个友善、幽默、智能的微信聊天助手，用中文简短回复。
llm.temperature=0.7
llm.max-tokens=512
llm.max-history-rounds=10

# ==================== 视觉模型配置（读图片理解）====================
# 默认复用上面的 base-url 和 api-key，只改 model 即可
vision.model=qwen-vl-max

# ==================== 图片生成配置 ====================
# 图片生成服务（目前支持通义万相）
imagegen.enabled=true
imagegen.base-url=https://dashscope.aliyuncs.com/api/v1/services/aigc/text2image/image-synthesis
imagegen.api-key=你的_api_key
imagegen.model=wan2.7-image-pro
# ========== API 密钥配置 ==========
# 复制本文件为 .env（.env 不会被提交到 Git）
# 或者直接在系统中设置环境变量

# 方式一：Windows 命令行设置（临时，仅当前窗口有效）
#   set OPENWEATHER_API_KEY=你的key
#   set DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 方式二：Windows 永久设置（需要重启终端/IDE）
#   setx OPENWEATHER_API_KEY "你的key"
#   setx DEEPSEEK_API_KEY "sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# 方式三：Java 启动参数
#   java -Dopenweather.api.key=你的key -Ddeepseek.api.key=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx -jar your-app.jar

# OpenWeather API Key — https://openweathermap.org/api
OPENWEATHER_API_KEY=your_openweather_api_key_here

# DeepSeek API Key — https://platform.deepseek.com/
DEEPSEEK_API_KEY=your_deepseek_api_key_here
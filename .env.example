# ========== API 密钥配置 ==========
# 复制本文件为 .env（.env 不会被提交到 Git）
# 或者直接在系统中设置环境变量

# 方式一：Windows 命令行设置（临时，仅当前窗口有效）
#   set DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
#   set DASHSCOPE_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
#   set AMAP_WEATHER_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 方式二：Windows 永久设置（需要重启终端/IDE）
#   setx DEEPSEEK_API_KEY "sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
#   setx DASHSCOPE_API_KEY "sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
#   setx AMAP_WEATHER_API_KEY "xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# 方式三：Java 启动参数也可以覆盖 application.properties 中的同名配置项。

# 高德开放平台 Web 服务 Key（天气查询）— https://console.amap.com/
AMAP_WEATHER_API_KEY=your_amap_weather_api_key_here

# DeepSeek API Key — https://platform.deepseek.com/
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# 阿里云百炼 API Key — https://bailian.console.aliyun.com/
DASHSCOPE_API_KEY=your_dashscope_api_key_here
